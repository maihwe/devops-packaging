# ============================================================
# .env.staging — Staging Environment
# ============================================================

DJANGO_ENV=staging
SECRET_KEY=staging-secret-key-replace-with-real-one
DEBUG=False
ALLOWED_HOSTS=staging.devops-django.com,localhost

DB_ENGINE=django.db.backends.postgresql
DB_NAME=devops_django_db_staging
DB_USER=staging_user
DB_PASSWORD=staging_password
DB_HOST=staging-db.internal
DB_PORT=5432
